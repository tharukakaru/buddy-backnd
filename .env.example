APP_NAME=Buddy AI Backend
APP_ENV=local

# PostgreSQL — use DATABASE_URL for Supabase/hosted, or individual vars for local Docker
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=buddy_db
POSTGRES_USER=buddy
POSTGRES_PASSWORD=buddy_password

# Qdrant vector DB
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=buddy_documents

# LLM — use deepseek or openai
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Embedding — use local (free) or openai
EMBEDDING_PROVIDER=local
OPENAI_API_KEY=your_openai_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
